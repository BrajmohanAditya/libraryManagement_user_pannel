                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CANCELLED\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/bookings/{{booking_id}}?adminId={{admin_id}}",
              "host": ["{{base_url}}"],
              "path": ["bookings", "{{booking_id}}"],
              "query": [
                {
                  "key": "adminId",
                  "value": "{{admin_id}}"
                }
              ]
            }
          }
        },
