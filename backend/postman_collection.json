      "name": "Auth",
      "item": [
        {
          "name": "User Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"number\": \"9876543210\",\n  \"state\": \"Maharashtra\",\n  \"city\": \"Mumbai\",\n  \"address\": \"123 Main Street\",\n  \"gender\": \"Male\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/signup",
              "host": ["{{base_url}}"],
              "path": ["users", "signup"]
            }
          }
        },
        {
          "name": "User Login",
          "request": {
            "method": "POST",
