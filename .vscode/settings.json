{
  "files.exclude": {
    "**/node_modules": true,
    "**/tsconfig.json": true,
    "**/.gitignore": true,
    "**/package.json": true,
    "**/package-lock.json": true,
    "**/components.json": true,
    "**/next.config.ts": true,
    "**/build": true,
    "**/jsconfig.json":true,
    "**/eslint.config.js":true,
    "**/vite.config.js":true
  },
  "explorer.compactFolders": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}